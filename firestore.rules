rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (userExists() && (getUserData().role == 'hr' || getUserData().role == 'gerencia')) ||
        (request.auth.token.email == "nmrm01@gmail.com") ||
        (request.auth.token.email == "asis.tthh@compufacil.com.ec") ||
        (request.auth.token.email == "tthh@compufacil.com.ec")
      );
    }

    function isHR() {
      return isAdmin();
    }
    
    function isManager() {
      return isAuthenticated() && userExists() && (getUserData().role == 'manager' || getUserData().role == 'gerencia');
    }

    function isGerencia() {
      return isAuthenticated() && userExists() && getUserData().role == 'gerencia';
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'role', 'position', 'managerUid', 'entryDate', 'totalVacationDays', 'usedVacationDays', 'pendingVacationDays', 'manualVacationPeriod']) &&
             data.uid is string &&
             data.displayName is string &&
             data.email is string &&
             data.role in ['employee', 'manager', 'hr', 'gerencia'] &&
             data.position is string &&
             (!('managerUid' in data) || data.managerUid is string) &&
             data.entryDate is string &&
             data.totalVacationDays is number &&
             data.usedVacationDays is number &&
             data.pendingVacationDays is number &&
             (!('manualVacationPeriod' in data) || data.manualVacationPeriod is string);
    }

    function isValidRequest(data) {
      return hasOnlyAllowedFields(['id', 'userUid', 'userName', 'type', 'startDate', 'endDate', 'status', 'reason', 'createdAt', 'updatedAt', 'managerApproverUid', 'gerenciaApproverUid', 'hrApproverUid', 'replacementApproverUid', 'managerUid', 'replacementUid', 'replacementName', 'managerApproverName', 'gerenciaApproverName', 'hrApproverName', 'replacementApproverName', 'cancellationReason', 'cancelledAt']) &&
             data.userUid is string &&
             data.type in ['vacation', 'permission'] &&
             data.status in ['pending_manager', 'pending_gerencia', 'pending_replacement', 'pending_hr', 'approved', 'rejected', 'cancelled'] &&
             data.startDate is string &&
             data.endDate is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated() || (resource.data.role in ['manager', 'hr', 'gerencia']);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (
        (request.auth.token.email == "nmrm01@gmail.com") ||
        (userExists() && getUserData().role == 'gerencia') ||
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingVacationDays']))
      ) && isValidUser(request.resource.data);
      allow delete: if isHR() && 
                      get(/databases/$(database)/documents/users/$(userId)).data.email != 'nmrm01@gmail.com' &&
                      get(/databases/$(database)/documents/users/$(userId)).data.email != 'asis.tthh@compufacil.com.ec';
    }

    // Requests
    match /requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userUid || 
        isHR() || 
        isGerencia() ||
        (isManager() && (resource.data.managerUid == request.auth.uid || resource.data.userUid == request.auth.uid)) ||
        (resource.data.replacementUid == request.auth.uid)
      );
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAuthenticated() && isValidRequest(request.resource.data) && (
        isHR() || 
        isGerencia() ||
        (isManager() && resource.data.managerUid == request.auth.uid && resource.data.status == 'pending_manager') ||
        (resource.data.replacementUid == request.auth.uid && resource.data.status == 'pending_replacement') ||
        (resource.data.userUid == request.auth.uid && resource.data.status != 'rejected' && resource.data.status != 'cancelled')
      );
      allow delete: if isHR();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if false; // Only server-side via Admin SDK
      allow update, delete: if false; // Immutable
    }
  }
}
